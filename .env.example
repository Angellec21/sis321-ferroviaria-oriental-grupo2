# ============================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ============================================
# Copiar este archivo a .env y llenar con valores reales

# Servidor
PORT=3000
NODE_ENV=development
API_URL=http://localhost:3000

# Base de Datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dss_ferroviaria
DB_USER=postgres
DB_PASSWORD=postgres
DB_SCHEMA=dw

# JWT
JWT_SECRET=tu_secreto_super_seguro_cambiar_en_produccion_12345
JWT_EXPIRATION=24h
REFRESH_TOKEN_SECRET=refresh_secreto_cambiar_en_produccion
REFRESH_TOKEN_EXPIRATION=7d

# Seguridad
BCRYPT_ROUNDS=10
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=debug

# SMTP (Para recuperación de contraseña - opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_app_password

# Aplicación
APP_NAME=DSS Ferroviaria Oriental
APP_VERSION=1.0.0

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
